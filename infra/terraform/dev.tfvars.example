# Template for dev.tfvars. Copy to dev.tfvars and fill in real values:
#   cp dev.tfvars.example dev.tfvars
# dev.tfvars is gitignored — your project_id never enters the repo.
# No real secrets here either: the NASS API key lives in Secret Manager.
project_id = "your-gcp-project-id"

region      = "us-central1"
bq_location = "US"

# Dev: allow clean teardown so `terraform destroy` works end-to-end.
bucket_force_destroy  = true
dataset_force_destroy = true

# Orchestration deferred to Phase 4. Flip to true only after setting a verified
# composer_image_version (gcloud composer images list --location=us-central1).
enable_composer = false
